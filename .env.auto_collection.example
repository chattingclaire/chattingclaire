# 微信自动收集配置示例
# 复制此文件为 .env 并填入你的配置

# ============================================================================
# 监控目录配置
# ============================================================================

# 监控的微信导出目录（系统会自动处理这个目录下的新文件）
WECHAT_WATCH_DIR=data/wechat/auto_exports

# ============================================================================
# 企业微信配置（可选）
# ============================================================================

# 如果你有企业微信，填入以下配置以启用企业微信自动接收
# 获取方式：https://work.weixin.qq.com/

# 企业ID
# WECOM_CORP_ID=ww1234567890abcdef

# 应用ID
# WECOM_AGENT_ID=1000001

# 应用Secret
# WECOM_SECRET=your_secret_here

# ============================================================================
# 公众号RSS配置（可选）
# ============================================================================

# 微信公众号RSS订阅链接（使用WeRSS等服务）
# 多个链接用逗号分隔
# 获取RSS链接：https://werss.app/

# 示例：
# WECHAT_RSS_FEEDS=https://werss.app/feed/xxx,https://werss.app/feed/yyy

# ============================================================================
# Pipeline自动触发（可选）
# ============================================================================

# 是否在检测到新内容时自动运行交易Pipeline
# true = 自动运行（生成股票推荐）
# false = 只收集和索引，不运行Pipeline
AUTO_RUN_PIPELINE=false

# ============================================================================
# 已有配置（保持不变）
# ============================================================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key

# OpenAI（用于embeddings）
OPENAI_API_KEY=sk-proj-...

# Anthropic（用于agents）
ANTHROPIC_API_KEY=sk-ant-api03-...

# Tushare（A股数据）
TUSHARE_TOKEN=your_tushare_token
